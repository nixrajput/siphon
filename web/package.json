{
  "name": "siphon-web",
  "version": "1.0.0",
  "private": true,
  "description": "Landing page and documentation for siphon, deployed on Vercel.",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"{app,components,lib}/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"{app,components,lib}/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "gray-matter": "^4.0.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "rehype-slug": "^6.0.0",
    "rehype-highlight": "^7.0.2"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3",
    "tailwindcss": "^4.3.1",
    "@tailwindcss/postcss": "^4.3.1",
    "postcss": "^8.5.15",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "prettier": "^3.8.5",
    "prettier-plugin-tailwindcss": "^0.8.0"
  }
